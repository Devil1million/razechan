# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#   RazeChan Bot — Environment Variables
#   Copy this file to .env and fill in values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Telegram API — https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Bot Token — @BotFather pe /newbot se milega
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MongoDB — https://mongodb.com/atlas (free tier)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/razechan

# Telegram Owner & DB Channel
OWNER_ID=123456789
DB_CHANNEL_ID=-1001234567890

# Groq AI (free) — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (voice notes) — https://elevenlabs.io
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Feature Toggles
GAMES_ENABLED=True
